# Database Configuration
POSTGRES_DB=gitduppy
POSTGRES_USER=gitduppy
POSTGRES_PASSWORD=gitduppy
DATABASE_URL=postgres://gitduppy:gitduppy@postgres:5432/gitduppy?sslmode=disable

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# Encryption Key (required for production)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# OAuth2 Configuration
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=

# Production Caddy Configuration
docker-compose.prod.yml specific:
DOMAIN=yourdomain.com
EMAIL=admin@yourdomain.com