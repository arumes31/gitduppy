{
    "info": {
        "_postman_id": "gitduppy-api-collection",
        "name": "GitDuppy API Collection",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "API collection for GitDuppy - Git repository mirroring and management platform"
    },
    "item": [
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Authenticate and receive a JWT token"
                    },
                    "response": []
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/auth/logout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "auth",
                                "logout"
                            ]
                        },
                        "description": "Invalidate the current session"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Repositories",
            "item": [
                {
                    "name": "List Repositories",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/repositories?page=1&per_page=20",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "repositories"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "per_page",
                                    "value": "20"
                                }
                            ]
                        },
                        "description": "List all repositories"
                    },
                    "response": []
                },
                {
                    "name": "Get Repository by ID",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/repositories/{{repository_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "repositories",
                                "{{repository_id}}"
                            ]
                        },
                        "description": "Get details of a specific repository"
                    },
                    "response": []
                },
                {
                    "name": "Create Repository",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"source_url\": \"https://github.com/user/repo.git\",\n  \"destination_path\": \"/mirrors/repo\",\n  \"schedule\": \"0 */6 * * *\",\n  \"ssh_key\": \"-----BEGIN RSA PRIVATE KEY-----\\n...\\n-----END RSA PRIVATE KEY-----\",\n  \"webhook_url\": \"https://example.com/webhook\",\n  \"tags\": [\"production\", \"critical\"]\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/repositories",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "repositories"
                            ]
                        },
                        "description": "Create a new repository"
                    },
                    "response": []
                },
                {
                    "name": "Update Repository",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"schedule\": \"0 */12 * * *\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/repositories/{{repository_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "repositories",
                                "{{repository_id}}"
                            ]
                        },
                        "description": "Update an existing repository"
                    },
                    "response": []
                },
                {
                    "name": "Delete Repository",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/repositories/{{repository_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "repositories",
                                "{{repository_id}}"
                            ]
                        },
                        "description": "Delete a repository"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Clone Jobs",
            "item": [
                {
                    "name": "List Clone Jobs",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/clone-jobs?status=failed",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "clone-jobs"
                            ],
                            "query": [
                                {
                                    "key": "status",
                                    "value": "failed"
                                }
                            ]
                        },
                        "description": "List all clone jobs"
                    },
                    "response": []
                },
                {
                    "name": "Trigger Manual Clone Job",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"repository_id\": {{repository_id}}\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/clone-jobs",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "clone-jobs"
                            ]
                        },
                        "description": "Trigger a manual clone job"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Users",
            "item": [
                {
                    "name": "List Users",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/users",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "users"
                            ]
                        },
                        "description": "List all users (admin only)"
                    },
                    "response": []
                },
                {
                    "name": "Create User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"securepassword123\",\n  \"role\": \"user\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/users",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "users"
                            ]
                        },
                        "description": "Create a new user (admin only)"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Health Check",
            "item": [
                {
                    "name": "System Health",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/health",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "health"
                            ]
                        },
                        "description": "Get system health status"
                    },
                    "response": []
                }
            ]
        }
    ],
    "event": [
